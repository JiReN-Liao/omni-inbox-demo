# Copy to .env and fill in real values. NEVER commit .env or real secrets.
# Example values only — do not use these passwords in any real environment.

# HTTP
PORT=4317
PUBLIC_BASE_URL=https://your-domain.example

# First administrator bootstrap.
# On startup, if NO admin credential exists yet, an admin is created from these
# and the password is immediately scrypt-hashed (the plaintext is never stored
# or logged). If an admin already exists, these are ignored — they never
# overwrite an existing password. Unset them again after the first launch.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-long-random-password

# Sessions (optional overrides; sensible defaults apply when unset).
# SESSION_TTL_MS=43200000        # session lifetime, default 12h
# LOGIN_MAX_ATTEMPTS=5           # failed logins before a temporary lockout
# LOGIN_LOCK_MS=900000           # lockout duration, default 15m
# OMNI_AUTH_DB_PATH=omni-auth.sqlite   # where credentials + sessions live
